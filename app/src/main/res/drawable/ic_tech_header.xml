<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="400dp"
    android:height="300dp"
    android:viewportWidth="400"
    android:viewportHeight="300">

    <!-- Deep Tech Background -->
    <path android:pathData="M0,0 h400 v300 h-400z">
        <aapt:attr name="android:fillColor">
            <gradient android:centerX="300" android:centerY="100" android:gradientRadius="400" android:type="radial">
                <item android:color="#1A237E" android:offset="0" />
                <item android:color="#000000" android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Circuit Grid Pattern -->
    <path android:strokeColor="#1FFFFFFF" android:strokeWidth="0.5" android:pathData="M0,50 h400 M0,100 h400 M0,150 h400 M0,200 h400 M50,0 v300 M100,0 v300 M150,0 v300 M200,0 v300 M250,0 v300 M300,0 v300 M350,0 v300" />

    <!-- Smartphone Silhouette -->
    <path android:fillColor="#212121" android:pathData="M280,60 h70 c8,0 12,4 12,12 v160 c0,8 -4,12 -12,12 h-70 c-8,0 -12,-4 -12,-12 v-160 c0,-8 4,-12 12,-12z" />
    <path android:fillColor="#000000" android:pathData="M285,70 h60 v140 h-60z" />

    <!-- Glowing Screen Effect -->
    <path android:pathData="M285,70 h60 v140 h-60z">
        <aapt:attr name="android:fillColor">
            <gradient android:startX="285" android:startY="70" android:endX="345" android:endY="210" android:type="linear">
                <item android:color="#334FC3F7" android:offset="0" />
                <item android:color="#11000000" android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Arc of Moving Coins -->
    <path android:pathData="M40,250 Q100,50 310,140" android:strokeWidth="2" android:strokeColor="#40FFD700" />

    <!-- Coin 1 (Gold) -->
    <path android:fillColor="#FFD700" android:pathData="M60,220 m-12,0 a12,12 0 1,0 24,0 a12,12 0 1,0 -24,0" />
    <path android:fillColor="#B8860B" android:pathData="M60,220 m-8,0 a8,8 0 1,0 16,0 a8,8 0 1,0 -16,0" />

    <!-- Coin 2 (Gold) -->
    <path android:fillColor="#FFD700" android:pathData="M130,120 m-10,0 a10,10 0 1,0 20,0 a10,10 0 1,0 -20,0" />

    <!-- Coin 3 (Gold) -->
    <path android:fillColor="#FFD700" android:pathData="M220,80 m-8,0 a8,8 0 1,0 16,0 a8,8 0 1,0 -16,0" />

    <!-- Glowing Nodes -->
    <path android:fillColor="#4FC3F7" android:pathData="M315,140 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0" />
    <path android:fillColor="#BB86FC" android:pathData="M315,160 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0" />

</vector>